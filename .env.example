# =============================================
# SIA3002C - Variables de Entorno
# Copia este archivo como .env y completa los valores
# =============================================

# Django
SECRET_KEY=django-insecure-cambia-esto-por-una-clave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================
# Base de Datos - Supabase (PostgreSQL)
# Obtén estos datos en: Supabase Dashboard > Project Settings > Database
# =============================================
DB_HOST=db.ghkbfggibasmuebsrdgg.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_DE_SUPABASE_AQUI

# =============================================
# LLM - Google Gemini
# Obtén tu API key GRATIS en: https://aistudio.google.com/apikey
# =============================================
GEMINI_API_KEY=TU_API_KEY_DE_GEMINI_AQUI
GEMINI_MODEL=gemini-1.5-flash

# =============================================
# Configuración del Modelo IA
# =============================================
MODEL_VERSION=1.0.0
RANDOM_SEED=42
